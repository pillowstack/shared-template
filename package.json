{
  "name": "@pillowstack/shared-template",
  "version": "1.0.0",
  "description": "Shared styles and types for hybrid projects",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix && stylelint \"**/*.{css,scss}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stylelint": "stylelint \"**/*.{css,scss}\"",
    "build": "tsc -p tsconfig.build.json",
    "clean": "find types -type f -name '*.d.ts' -delete && find types -type f -name '*.d.ts.map' -delete",
    "pack": "npm pack",
    "prepack": "npm run clean && npm run build",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.1",
    "postcss": "^8.5.6",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.6.2",
    "stylelint": "^16.24.0",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0"
  },
  "license": "MIT",
  "lint-staged": {
    "*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{js,ts,jsx,tsx,vue,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,ts,jsx,tsx,vue}": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "types": "./types/index.d.ts",
  "files": [
    "types",
    "styles"
  ],
  "sass": "./styles/_index.scss",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./types/index.d.ts"
    },
    "./styles": "./styles/root.scss",
    "./styles/*": "./styles/*"
  },
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pillowstack/shared-template.git"
  },
  "bugs": {
    "url": "https://github.com/pillowstack/shared-template/issues"
  },
  "homepage": "https://github.com/pillowstack/shared-template",
  "author": "@pillowstack",
  "keywords": [
    "template",
    "eslint",
    "prettier",
    "husky",
    "styles",
    "scss",
    "types"
  ],
  "changelog": {
    "1.0.0": "Initial release"
  }
}
